package com.meta.wearable.dat.externalsampleapps.cameraaccess

object Secrets {
    // REQUIRED: Get your key at https://aistudio.google.com/apikey
    const val geminiAPIKey = "YOUR_GEMINI_API_KEY"

    // OPTIONAL: OpenClaw gateway config (for agentic tool-calling)
    // LAN example: http://192.168.0.10 with port 18789
    // ngrok example: https://abc123.ngrok-free.app with port 443
    // Do not include a trailing slash.
    const val openClawHost = "https://YOUR_OPENCLAW_HOST"
    const val openClawPort = 443
    // Current Android app flow does not use hook token; leave blank unless you expose /hooks/* separately.
    const val openClawHookToken = ""
    // Read with: openclaw config get gateway.auth.token
    const val openClawGatewayToken = "YOUR_OPENCLAW_GATEWAY_TOKEN"

    // OPTIONAL: RTMP publishing URL for local ingest/server-side recording
    const val rtmpEnabled = false
    const val rtmpPublishUrl = "rtmp://YOUR_SERVER_IP:1935/live/glasses"
}
